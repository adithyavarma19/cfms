NODE_ENV=development
PORT=3001

DB_HOST=localhost
DB_PORT=5432
DB_NAME=course_feedback
DB_USER=postgres
DB_PASSWORD=change_me
DB_SSL=false

JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=24h

# Single allowed production frontend origin.
CORS_ORIGIN=https://feedback.example.edu

# Optional: allow creating admin role via /api/auth/register
ALLOW_ADMIN_REGISTRATION=false

# Optional: one-time seed controls for npm run init-db
SEED_DEFAULT_ADMIN=false
DEFAULT_ADMIN_LOGIN=
DEFAULT_ADMIN_PASSWORD=
